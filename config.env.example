# OpenWebRX 2 m FT8/MSK144 DX bot - configuration
# Copy to config.env (the installer does this for you) and fill in the token.
# After any change:  systemctl restart ft8-dx-bot

# --- required: from @BotFather, and your numeric chat id --------------------
TELEGRAM_TOKEN=PUT_TOKEN_HERE
TELEGRAM_CHAT_ID=PUT_CHAT_ID_HERE

# --- what counts as a DX alert ---------------------------------------------
MIN_KM=200            # alert when a station is at least this far away
MAX_KM=3000           # ignore "impossible" distances (false decodes); 2 m tops ~2500 km
MODES=FT8,MSK144      # which modes to alert on (MSK144 = meteor scatter)
BAND_MIN_HZ=144000000 # 2 m band edges
BAND_MAX_HZ=146000000
EXPIRY_HOURS=24       # re-alert the same call+grid only after this many hours

# --- false-decode filtering ------------------------------------------------
CONFIRM_DECODES=1     # require a call to be decoded N times before alerting
                      #   1 = off (instant). Set 2 if junk slips through within MAX_KM.
CONFIRM_WINDOW_MIN=10
CONFIRM_MODES=FT8,FT4 # confirmation applies to these modes only (not sparse MSK144)
MIN_SNR=              # blank = off; e.g. -23 to drop the very weakest decodes

# --- Es opening detector ---------------------------------------------------
OPENING_DX_KM=500       # a spot must beat this to count toward an opening
OPENING_MIN_STATIONS=4  # this many distinct DX in the window => "band is open"
OPENING_WINDOW_MIN=5
OPENING_CLOSE_MIN=12    # quiet minutes before the opening is declared closed

# --- local MQTT broker (OpenWebRX publishes decodes here) ------------------
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=openwebrx/#

# --- optional: override location / callsign (else read from OpenWebRX) -----
# RX_LAT=55.2454
# RX_LON=22.2769
# RX_CALL=LY5AT
# OWRX_SETTINGS=/var/lib/openwebrx/settings.json
